# Secrets — never committed
.env

# Data (large, regenerable or continuously growing) — root-anchored so that
# src/cryptoacademy/data/ (source code!) is NOT ignored
/data/
/logs/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/

# ML artifacts (tracked via MLflow, not git)
mlruns/
mlflow.db

# OS/editor
Thumbs.db
.DS_Store

# Exception: the trial registry is the statistical foundation (DSR N) and is
# NOT re-downloadable — it must survive disk failure. Small append-only JSONL.
!data/
data/*
!data/trials/
!data/trials/trials.jsonl
data/trials/*
!data/trials/trials.jsonl
